<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/obsidian_lowest"
    tools:context=".HistoryActivity">

    <!-- ══════════════════════════════════════════ -->
    <!-- HEADER                                     -->
    <!-- ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/historyHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="16dp"
        android:background="@color/obsidian_lowest"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Nav back row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/toolbar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:padding="6dp"
                app:tint="@color/text_med" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="ROADWISE"
                android:textColor="@color/emerald_neon"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.15" />

            <com.google.android.material.button.MaterialButton
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="16dp"
                android:text="EXPORT"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:textColor="@color/emerald_neon"
                app:strokeColor="@color/emerald_neon"
                app:strokeWidth="1dp"
                app:cornerRadius="999dp" />
        </LinearLayout>

        <!-- Title row -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Drive History"
            android:textColor="@color/text_high"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:textSize="28sp" />

        <TextView
            android:id="@+id/tvSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textColor="@color/text_low"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"
            android:visibility="gone" />

        <!-- Neon bottom line -->
        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_marginTop="12dp"
            android:background="@color/emerald_neon" />
    </LinearLayout>

    <!-- ══════════════════════════════════════════ -->
    <!-- HAZARD LIST                                -->
    <!-- ══════════════════════════════════════════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPotholes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/historyHeader"
        tools:listitem="@layout/item_pothole" />

    <!-- ══════════════════════════════════════════ -->
    <!-- EMPTY STATE                                -->
    <!-- ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/historyHeader">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardBackgroundColor="@color/glass_surface"
            app:cardCornerRadius="999dp"
            app:strokeColor="@color/glass_border"
            app:strokeWidth="1dp"
            android:layout_marginBottom="20dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="20dp"
                android:src="@drawable/ic_history"
                app:tint="@color/text_low" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Hazards Logged"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/text_high"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Drive to automatically detect and record road anomalies."
            android:layout_marginTop="8dp"
            android:textSize="13sp"
            android:gravity="center"
            android:textColor="@color/text_low" />
    </LinearLayout>

    <!-- ══════════════════════════════════════════ -->
    <!-- EXPORT FAB                                 -->
    <!-- ══════════════════════════════════════════ -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExportPdf"
        android:layout_width="wrap_content"
        android:layout_height="54dp"
        android:layout_margin="24dp"
        android:text="EXPORT PDF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/obsidian_background"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.06"
        app:backgroundTint="@color/emerald_neon"
        app:cornerRadius="999dp"
        app:icon="@drawable/ic_export"
        app:iconTint="@color/obsidian_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
