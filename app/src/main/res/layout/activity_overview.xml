<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- Full Screen Map -->
    <org.osmdroid.views.MapView
        android:id="@+id/overviewMap"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Unified Top Dashboard Panel -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topDashboardCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="?attr/glassSurfaceDeep"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:strokeColor="?attr/glassBorder"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="12dp">

            <!-- Title Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp">

                <ImageButton
                    android:id="@+id/btnOverviewBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_close"
                    android:padding="8dp"
                    app:tint="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Infrastructure Control"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="?attr/colorOnSurface" />

                <ImageButton
                    android:id="@+id/btnExportReport"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_export"
                    android:padding="8dp"
                    app:tint="?attr/colorOnSurface" />
            </LinearLayout>

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL HAZARDS"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="?attr/textFaded"
                        android:letterSpacing="0.1" />
                    <TextView
                        android:id="@+id/tvTotalPotholes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-bold"
                        android:textColor="@color/electric_gold" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_marginVertical="4dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="?attr/glassBorder" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CRITICAL ACTION REQ."
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="?attr/textFaded"
                        android:letterSpacing="0.1" />
                    <TextView
                        android:id="@+id/tvCriticalCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-bold"
                        android:textColor="#EF4444" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/glassBorder" />

            <!-- Filters -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupFilters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:selectionRequired="true"
                    app:singleLine="true"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAll"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="Map View: All Elements"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="?attr/glassBorder"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipCritical"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Critical Only (Grade D/F)"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="?attr/glassBorder"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipModerate"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Moderate Watchlist"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="?attr/glassBorder"
                        app:chipStrokeWidth="1dp" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Map Legend (Bottom Left Floating) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/legendCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:layout_marginBottom="80dp"
        app:cardBackgroundColor="?attr/glassSurface"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:strokeColor="?attr/glassBorder"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/btnShowList"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HEATMAP LEGEND"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="?attr/textFaded"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/circle_indicator" android:backgroundTint="#2ECC71" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stable" android:textSize="12sp" android:textColor="?attr/colorOnSurface"/>
            </LinearLayout>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/circle_indicator" android:backgroundTint="#F4D03F" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Erosion" android:textSize="12sp" android:textColor="?attr/colorOnSurface"/>
            </LinearLayout>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical">
                <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/circle_indicator" android:backgroundTint="#E74C3C" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hazardous" android:textSize="12sp" android:textColor="?attr/colorOnSurface"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Priority Repair List Button (Wide spanning bottom) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnShowList"
        style="@style/Widget.MaterialComponents.Button.Icon"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        android:text="OPEN REPAIR WORKFLOW"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="15sp"
        android:letterSpacing="0.05"
        app:backgroundTint="#10B981"
        app:cornerRadius="32dp"
        app:icon="@drawable/ic_alerts"
        app:iconSize="24dp"
        app:iconPadding="12dp"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Loading Overlay -->
    <ProgressBar
        android:id="@+id/overviewProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/emerald_neon"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
