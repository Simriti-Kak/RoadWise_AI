<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="5dp"
    app:cardBackgroundColor="@color/glass_surface"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/glass_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Left: Type Badge -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="52dp"
            android:layout_height="52dp">

            <!-- Colored ring glow -->
            <View
                android:id="@+id/typeRing"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/circle_indicator"
                android:backgroundTint="@color/electric_gold"
                android:alpha="0.18"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Thumbnail photo -->
            <ImageView
                android:id="@+id/ivThumbnail"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:scaleType="centerCrop"
                android:background="@android:color/transparent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Fallback icon -->
            <ImageView
                android:id="@+id/ivTypeIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_alerts"
                app:tint="@color/electric_gold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Right: Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvType"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="POTHOLE"
                    android:textColor="@color/electric_gold"
                    android:textSize="13sp"
                    android:letterSpacing="0.06"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnDelete"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_delete"
                    app:tint="#FF3B30"
                    android:alpha="0.7" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="28.6139° N, 77.2090° E"
                android:textColor="@color/text_med"
                android:fontFamily="monospace"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvDateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="OCT 24 · 20:18  ·  2.4G"
                android:textColor="@color/text_low"
                android:fontFamily="sans-serif-medium"
                android:textSize="10sp"
                android:letterSpacing="0.04" />

            <!-- Intensity Bar -->
            <ProgressBar
                android:id="@+id/pbIntensity"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="8dp"
                android:max="100"
                android:progress="60"
                android:progressTint="@color/electric_gold"
                android:progressBackgroundTint="@color/glass_border" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
