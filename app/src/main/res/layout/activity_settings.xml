<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    tools:context=".SettingsActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                android:textSize="24sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configure RoadWise"
                android:textColor="?attr/textFaded"
                android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardBackgroundColor="?attr/glassSurface"
            app:strokeColor="?attr/glassBorder"
            app:strokeWidth="1dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_settings"
                android:padding="10dp"
                app:tint="@color/emerald_neon" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="false"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNavCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <!-- ══════════════════════════════════════ -->
            <!-- SECTION: DETECTION ENGINE              -->
            <!-- ══════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DETECTION ENGINE"
                android:textColor="@color/emerald_neon"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeColor="?attr/glassBorder"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Background Monitoring -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toStartOf="@+id/switchBackgroundService"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Background Monitoring"
                                android:textColor="?attr/colorOnSurface"
                                android:textStyle="bold"
                                android:textSize="15sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Continuously check hazards when app is closed"
                                android:textColor="?attr/textFaded"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchBackgroundService"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:thumbTint="@color/emerald_neon"
                            app:trackTint="@color/emerald_neon" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/glassBorder"
                        android:layout_marginVertical="16dp" />

                    <!-- Auto-Start on Drive -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toStartOf="@+id/switchAutoStart"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Auto-Start on Drive"
                                android:textColor="?attr/colorOnSurface"
                                android:textStyle="bold"
                                android:textSize="15sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Uses motion sensors to detect when you're in a car"
                                android:textColor="?attr/textFaded"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchAutoStart"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:thumbTint="@color/emerald_neon"
                            app:trackTint="@color/emerald_neon" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/glassBorder"
                        android:layout_marginVertical="16dp" />

                    <!-- Battery Optimization -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toStartOf="@+id/btnBatteryOptimize"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Background Reliability"
                                android:textColor="?attr/colorOnSurface"
                                android:textStyle="bold"
                                android:textSize="15sp" />
                            <TextView
                                android:id="@+id/tvBatteryStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Allow app to run freely in background"
                                android:textColor="?attr/textFaded"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBatteryOptimize"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="Fix Now"
                            android:textColor="@color/emerald_neon" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/glassBorder"
                        android:layout_marginVertical="16dp" />

                    <!-- Background Detection (Legacy Label, now for Sensor only) -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toStartOf="@+id/switchBackground"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Background Detection"
                                android:textColor="?attr/colorOnSurface"
                                android:textStyle="bold"
                                android:textSize="15sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Analyze road conditions while using other apps"
                                android:textColor="?attr/textFaded"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchBackground"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:thumbTint="@color/emerald_neon"
                            app:trackTint="@color/emerald_neon" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/glassBorder"
                        android:layout_marginVertical="16dp" />

                    <!-- Sensitivity -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detection Sensitivity"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:textSize="15sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Adjust the G-force threshold for hazard detection"
                        android:textColor="?attr/textFaded"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderSensitivity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:valueFrom="0.0"
                        android:valueTo="2.0"
                        android:stepSize="1.0"
                        app:thumbColor="?attr/colorOnSurface"
                        app:trackColorActive="@color/emerald_neon"
                        app:trackColorInactive="?attr/glassBorder"
                        app:haloColor="@color/emerald_neon"
                        app:labelBehavior="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Reactive"
                            android:textColor="?attr/textFaded"
                            android:textSize="11sp" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Balanced"
                            android:textColor="?attr/textFaded"
                            android:textSize="11sp" />
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="Proactive"
                            android:textColor="@color/emerald_neon"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Current threshold label -->
                    <TextView
                        android:id="@+id/tvSensitivityLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Threshold: 3.8g (Balanced)"
                        android:textColor="?attr/textFaded"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════ -->
            <!-- SECTION: RESOURCE MANAGEMENT          -->
            <!-- ══════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RESOURCE MANAGEMENT"
                android:textColor="@color/emerald_neon"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeColor="?attr/glassBorder"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Battery Saver -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toStartOf="@+id/switchBattery"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Battery Saver Mode"
                                android:textColor="?attr/colorOnSurface"
                                android:textStyle="bold"
                                android:textSize="15sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Reduces GPS refresh rate to 2s (from 1s)"
                                android:textColor="?attr/textFaded"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchBattery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:thumbTint="@color/electric_gold"
                            app:trackTint="@color/electric_gold" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/glassBorder"
                        android:layout_marginVertical="16dp" />

                    <!-- Voice Hazard Alerts -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toStartOf="@+id/switchVoiceAlerts"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Voice Hazard Alerts"
                                android:textColor="?attr/colorOnSurface"
                                android:textStyle="bold"
                                android:textSize="15sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Announce approaching potholes and speedbumps"
                                android:textColor="?attr/textFaded"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchVoiceAlerts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:thumbTint="@color/emerald_neon"
                            app:trackTint="@color/emerald_neon" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/glassBorder"
                        android:layout_marginVertical="16dp" />

                    <!-- Audio Alerts -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Audio Alert Volume"
                                android:textColor="?attr/colorOnSurface"
                                android:textStyle="bold"
                                android:textSize="15sp" />
                            <TextView
                                android:id="@+id/tvAudioLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="65% — plays a tone on detection"
                                android:textColor="?attr/textFaded"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderAudio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:value="65.0"
                        android:valueFrom="0.0"
                        android:valueTo="100.0"
                        app:thumbColor="?attr/colorOnSurface"
                        app:trackColorActive="@color/electric_gold"
                        app:trackColorInactive="?attr/glassBorder"
                        app:haloColor="@color/electric_gold"
                        app:labelBehavior="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════ -->
            <!-- SECTION: DATA MANAGEMENT              -->
            <!-- ══════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATA MANAGEMENT"
                android:textColor="@color/emerald_neon"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeColor="?attr/glassBorder"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Storage Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Storage Used"
                                android:textColor="?attr/colorOnSurface"
                                android:textStyle="bold"
                                android:textSize="15sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Detection photos and map data"
                                android:textColor="?attr/textFaded"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="?attr/glassSurface"
                            app:cardCornerRadius="12dp"
                            app:strokeColor="?attr/glassBorder"
                            app:strokeWidth="1dp">
                            <TextView
                                android:id="@+id/tvStorageSize"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="@color/emerald_neon"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/glassBorder"
                        android:layout_marginVertical="16dp" />

                    <!-- Record count -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Detections"
                                android:textColor="?attr/colorOnSurface"
                                android:textStyle="bold"
                                android:textSize="15sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="All potholes and speed bumps on record"
                                android:textColor="?attr/textFaded"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="?attr/glassSurface"
                            app:cardCornerRadius="12dp"
                            app:strokeColor="?attr/glassBorder"
                            app:strokeWidth="1dp">
                            <TextView
                                android:id="@+id/tvRecordCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/electric_gold"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/glassBorder"
                        android:layout_marginVertical="16dp" />

                    <!-- Clear History Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearHistory"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Clear All History"
                        app:cornerRadius="14dp"
                        android:textColor="?attr/colorError"
                        app:strokeColor="?attr/colorError"
                        app:icon="@drawable/ic_delete"
                        app:iconTint="?attr/colorError"
                        app:iconGravity="textStart" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════ -->
            <!-- SECTION: ABOUT                        -->
            <!-- ══════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABOUT"
                android:textColor="@color/emerald_neon"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeColor="?attr/glassBorder"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Version Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Version"
                                android:textColor="?attr/colorOnSurface"
                                android:textStyle="bold"
                                android:textSize="15sp" />
                            <TextView
                                android:id="@+id/tvVersion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1.0.0"
                                android:textColor="?attr/textFaded"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_alerts"
                            app:tint="?attr/textFaded" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/glassBorder"
                        android:layout_marginVertical="16dp" />

                    <!-- Open-source Libraries Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Open-source Libraries"
                                android:textColor="?attr/colorOnSurface"
                                android:textStyle="bold"
                                android:textSize="15sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/os_libraries"
                                android:textColor="?attr/textFaded"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/glassBorder"
                        android:layout_marginVertical="16dp" />

                    <!-- Share App Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnShareApp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Share RoadWise"
                        app:cornerRadius="14dp"
                        android:textColor="@color/emerald_neon"
                        app:strokeColor="@color/emerald_neon"
                        app:icon="@drawable/ic_export"
                        app:iconTint="@color/emerald_neon"
                        app:iconGravity="textStart" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bottom spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="16dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Navigation Footer (Labeled, matching Main screen) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardBackgroundColor="?attr/glassSurfaceDeep"
        app:cardCornerRadius="40dp"
        app:cardElevation="20dp"
        app:strokeColor="?attr/glassBorder"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp">

            <LinearLayout
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/navDrive"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_drive"
                    app:tint="?attr/textFaded" />
                <TextView
                    android:id="@+id/navDriveLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Drive"
                    android:textSize="10sp"
                    android:textColor="?attr/textFaded" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="4dp">
                <ImageButton
                    android:id="@+id/navAlerts"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_alerts"
                    app:tint="?attr/textFaded" />
                <TextView
                    android:id="@+id/navAlertsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="History"
                    android:textSize="10sp"
                    android:textColor="?attr/textFaded" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="4dp">
                <ImageButton
                    android:id="@+id/navSettings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/emerald_neon" />
                <TextView
                    android:id="@+id/navSettingsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Settings"
                    android:textSize="10sp"
                    android:textColor="@color/emerald_neon"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="4dp">
                <ImageButton
                    android:id="@+id/navAccount"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_person"
                    app:tint="?attr/textFaded" />
                <TextView
                    android:id="@+id/navAccountLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Account"
                    android:textSize="10sp"
                    android:textColor="?attr/textFaded" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
