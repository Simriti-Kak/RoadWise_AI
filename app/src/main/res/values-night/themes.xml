<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.RoadWise" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Core Colors -->
        <item name="colorPrimary">@color/emerald_neon</item>
        <item name="colorPrimaryVariant">@color/emerald_neon</item>
        <item name="colorOnPrimary">@color/obsidian_background</item>
        <item name="colorSecondary">@color/electric_gold</item>
        <item name="colorSecondaryVariant">@color/electric_gold</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <item name="android:colorBackground">@color/obsidian_lowest</item>
        <item name="colorSurface">@color/obsidian_background</item>
        <item name="colorOnBackground">@color/text_high</item>
        <item name="colorOnSurface">@color/text_high</item>

        <!-- Custom Attributes -->
        <item name="glassSurface">@color/glass_surface</item>
        <item name="glassSurfaceDeep">@color/glass_surface_deep</item>
        <item name="glassBorder">@color/glass_border</item>
        <item name="textFaded">@color/text_med</item>

        <item name="android:statusBarColor">@color/obsidian_lowest</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="BottomSheetDialogTheme" parent="Theme.Design.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

</resources>
